<?xml version="1.0" encoding="UTF-8"?><!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd"><mapper namespace="com.ruoyi.mes.purchase.mapper.PurchaseReceiptMapper"><resultMap id="m" type="com.ruoyi.mes.purchase.domain.PurchaseReceipt"><id property="id" column="id"/><result property="receiptCode" column="receipt_code"/><result property="orderId" column="order_id"/><result property="orderCode" column="order_code"/><result property="supplierName" column="supplier_name"/><result property="receiptDate" column="receipt_date"/><result property="status" column="status"/><result property="inspectionStatus" column="inspection_status"/><result property="totalQuantity" column="total_quantity"/><result property="remark" column="remark"/></resultMap><select id="selectList" resultMap="m">select * from purchase_receipt<where><if test="receiptCode!=null and receiptCode!=''">and receipt_code like concat('%',#{receiptCode},'%')</if><if test="status!=null and status!=''">and status=#{status}</if></where> order by id desc</select><select id="selectById" resultMap="m">select * from purchase_receipt where id=#{id}</select><insert id="insert" useGeneratedKeys="true" keyProperty="id">insert into purchase_receipt(receipt_code,order_id,order_code,supplier_code,supplier_name,receipt_date,status,inspection_status,total_quantity,remark,create_by,create_time) values(#{receiptCode},#{orderId},#{orderCode},#{supplierCode},#{supplierName},#{receiptDate},#{status},#{inspectionStatus},#{totalQuantity},#{remark},#{createBy},now())</insert><update id="update">update purchase_receipt set receipt_code=#{receiptCode},receipt_date=#{receiptDate},status=#{status},inspection_status=#{inspectionStatus},total_quantity=#{totalQuantity},remark=#{remark},update_by=#{updateBy},update_time=now() where id=#{id}</update><delete id="deleteByIds">delete from purchase_receipt where id in <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach></delete><select id="selectLines" resultType="com.ruoyi.mes.purchase.domain.PurchaseReceiptLine">select * from purchase_receipt_line where receipt_id=#{receiptId} order by line_no</select><insert id="insertLine" useGeneratedKeys="true" keyProperty="id">insert into purchase_receipt_line(receipt_id,order_line_id,line_no,material_id,material_code,material_name,spec,unit,received_quantity,qualified_quantity,rejected_quantity,pending_quantity,lot_no,warehouse_code,location_code,remark,create_by,create_time) values(#{receiptId},#{orderLineId},#{lineNo},#{materialId},#{materialCode},#{materialName},#{spec},#{unit},#{receivedQuantity},#{qualifiedQuantity},#{rejectedQuantity},#{pendingQuantity},#{lotNo},#{warehouseCode},#{locationCode},#{remark},#{createBy},now())</insert><delete id="deleteLines">delete from purchase_receipt_line where receipt_id in <foreach collection="list" item="id" open="(" separator="," close=")">#{id}</foreach></delete></mapper>
