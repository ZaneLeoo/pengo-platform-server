<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mes.purchase.mapper.InventoryBalanceMapper">
    <resultMap id="m" type="com.ruoyi.mes.purchase.domain.InventoryBalance">
        <id property="id" column="id"/><result property="materialId" column="material_id"/>
        <result property="materialCode" column="material_code"/><result property="materialName" column="material_name"/>
        <result property="warehouseCode" column="warehouse_code"/><result property="warehouseName" column="warehouse_name"/>
        <result property="locationCode" column="location_code"/><result property="locationName" column="location_name"/>
        <result property="lotNo" column="lot_no"/><result property="productionDate" column="production_date"/>
        <result property="expiryDate" column="expiry_date"/><result property="unit" column="unit"/>
        <result property="remainingShelfLifeDays" column="remaining_shelf_life_days"/><result property="expiryStatus" column="expiry_status"/>
        <result property="quantity" column="quantity"/><result property="availableQuantity" column="available_quantity"/>
        <result property="lockedQuantity" column="locked_quantity"/><result property="status" column="status"/>
    </resultMap>
    <sql id="selectBalance">select b.*,
        case when b.expiry_date is null then null else datediff(b.expiry_date, curdate()) end as remaining_shelf_life_days,
        case when b.expiry_date is null then 'UNMANAGED' when b.expiry_date &lt; curdate() then 'EXPIRED'
             when b.expiry_date &lt;= date_add(curdate(), interval coalesce(m.expiry_warning_days, 30) day) then 'EXPIRING'
             else 'VALID' end as expiry_status
        from inventory_balance b left join material m on m.material_id=b.material_id</sql>
    <select id="selectList" resultMap="m"><include refid="selectBalance"/><where><if test="materialCode!=null and materialCode!=''">and b.material_code like concat('%',#{materialCode},'%')</if><if test="warehouseCode!=null and warehouseCode!=''">and b.warehouse_code=#{warehouseCode}</if><if test="status!=null and status!=''">and b.status=#{status}</if></where> order by b.id desc</select>
    <select id="selectById" resultMap="m"><include refid="selectBalance"/> where b.id=#{id}</select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">insert into inventory_balance(material_id,material_code,material_name,warehouse_code,warehouse_name,location_code,location_name,lot_no,production_date,expiry_date,unit,quantity,available_quantity,locked_quantity,status,remark,create_by,create_time) values(#{materialId},#{materialCode},#{materialName},#{warehouseCode},#{warehouseName},#{locationCode},#{locationName},#{lotNo},#{productionDate},#{expiryDate},#{unit},#{quantity},#{availableQuantity},#{lockedQuantity},#{status},#{remark},#{createBy},now())</insert>
    <update id="update">update inventory_balance set production_date=#{productionDate},expiry_date=#{expiryDate},quantity=#{quantity},available_quantity=#{availableQuantity},locked_quantity=#{lockedQuantity},status=#{status},remark=#{remark},update_by=#{updateBy},update_time=now() where id=#{id}</update>
    <delete id="deleteByIds">delete from inventory_balance where id in <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
