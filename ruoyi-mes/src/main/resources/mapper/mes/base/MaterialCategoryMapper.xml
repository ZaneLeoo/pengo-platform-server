<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mes.base.mapper.MaterialCategoryMapper">

    <resultMap id="MaterialCategoryResult" type="MaterialCategory">
        <id property="categoryId" column="category_id"/>
        <result property="parentId" column="parent_id"/>
        <result property="ancestors" column="ancestors"/>
        <result property="categoryCode" column="category_code"/>
        <result property="categoryName" column="category_name"/>
        <result property="orderNum" column="order_num"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="selectCategoryVo">
        select category_id, parent_id, ancestors, category_code, category_name, order_num, status,
               create_by, create_time, update_by, update_time, remark
        from material_category
    </sql>

    <select id="selectCategoryList" parameterType="MaterialCategory" resultMap="MaterialCategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            <if test="categoryCode != null and categoryCode != ''">
                AND category_code like concat('%', #{categoryCode}, '%')
            </if>
            <if test="categoryName != null and categoryName != ''">
                AND category_name like concat('%', #{categoryName}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by parent_id, order_num, category_id
    </select>

    <select id="selectCategoryListForAgent" resultMap="MaterialCategoryResult">
        <include refid="selectCategoryVo"/>
        <where>
            <if test="keyword != null and keyword != ''">
                AND (category_code like concat('%', #{keyword}, '%')
                  OR category_name like concat('%', #{keyword}, '%'))
            </if>
            <if test="parentId != null">
                AND parent_id = #{parentId}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by parent_id, order_num, category_id
    </select>

    <select id="selectCategoryById" parameterType="Long" resultMap="MaterialCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_id = #{categoryId}
    </select>

    <select id="selectCategoryByCode" parameterType="String" resultMap="MaterialCategoryResult">
        <include refid="selectCategoryVo"/>
        where category_code = #{categoryCode}
        limit 1
    </select>

    <select id="countChildrenById" parameterType="Long" resultType="int">
        select count(1) from material_category where parent_id = #{categoryId}
    </select>

    <insert id="insertCategory" parameterType="MaterialCategory" useGeneratedKeys="true" keyProperty="categoryId">
        insert into material_category(
            parent_id, ancestors, category_code, category_name, order_num, status, remark, create_by, create_time
        ) values (
            #{parentId}, #{ancestors}, #{categoryCode}, #{categoryName}, #{orderNum}, #{status}, #{remark}, #{createBy}, sysdate()
        )
    </insert>

    <update id="updateCategory" parameterType="MaterialCategory">
        update material_category
        <set>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="ancestors != null and ancestors != ''">ancestors = #{ancestors},</if>
            <if test="categoryCode != null and categoryCode != ''">category_code = #{categoryCode},</if>
            <if test="categoryName != null and categoryName != ''">category_name = #{categoryName},</if>
            <if test="orderNum != null">order_num = #{orderNum},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where category_id = #{categoryId}
    </update>

    <delete id="deleteCategoryById" parameterType="Long">
        delete from material_category where category_id = #{categoryId}
    </delete>

</mapper>
