<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.mes.base.mapper.BomVersionMapper">
    <resultMap id="BomVersionResult" type="BomVersion">
        <id property="id" column="id"/>
        <result property="bomMasterId" column="bom_master_id"/>
        <result property="versionCode" column="version_code"/>
        <result property="versionName" column="version_name"/>
        <result property="versionDesc" column="version_desc"/>
        <result property="baseQty" column="base_qty"/>
        <result property="usageType" column="usage_type"/>
        <result property="effectiveDate" column="effective_date"/>
        <result property="expireDate" column="expire_date"/>
        <result property="status" column="status"/>
        <result property="approveStatus" column="approve_status"/>
        <result property="defaultFlag" column="default_flag"/>
        <result property="defaultRoutingCode" column="default_routing_code"/>
        <result property="defaultRoutingName" column="default_routing_name"/>
        <result property="defaultRoutingVersionId" column="default_routing_version_id"/>
        <result property="sourceSystem" column="source_system"/>
        <result property="sourceId" column="source_id"/>
        <result property="checkBy" column="check_by"/>
        <result property="checkTime" column="check_time"/>
        <result property="closeBy" column="close_by"/>
        <result property="closeTime" column="close_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>
    <sql id="selectBomVersionVo">
        select id,bom_master_id,version_code,version_name,version_desc,base_qty,usage_type,effective_date,expire_date,status,approve_status,default_flag,default_routing_code,default_routing_name,default_routing_version_id,source_system,source_id,check_by,check_time,close_by,close_time,create_by,create_time,update_by,update_time,remark from bom_version
    </sql>
    <select id="selectBomVersionList" parameterType="BomVersion" resultMap="BomVersionResult">
        <include refid="selectBomVersionVo"/>
        <where>
            <if test="bomMasterId != null">and bom_master_id = #{bomMasterId}</if>
            <if test="versionCode != null and versionCode != ''">and version_code like concat('%', #{versionCode}, '%')</if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by default_flag desc, create_time desc
    </select>
    <select id="selectBomVersionById" parameterType="Long" resultMap="BomVersionResult"><include refid="selectBomVersionVo"/> where id=#{id}</select>
    <select id="selectBomVersionByCode" resultMap="BomVersionResult"><include refid="selectBomVersionVo"/> where bom_master_id=#{bomMasterId} and version_code=#{versionCode} limit 1</select>
    <update id="resetDefaultFlag">update bom_version set default_flag=0 where bom_master_id=#{bomMasterId}<if test="excludeId != null"> and id != #{excludeId}</if></update>
    <insert id="insertBomVersion" parameterType="BomVersion" useGeneratedKeys="true" keyProperty="id">
        insert into bom_version(bom_master_id,version_code,version_name,version_desc,base_qty,usage_type,effective_date,expire_date,status,approve_status,default_flag,default_routing_code,default_routing_name,default_routing_version_id,source_system,source_id,check_by,check_time,close_by,close_time,remark,create_by,create_time)
        values(#{bomMasterId},#{versionCode},#{versionName},#{versionDesc},#{baseQty},#{usageType},#{effectiveDate},#{expireDate},#{status},#{approveStatus},#{defaultFlag},#{defaultRoutingCode},#{defaultRoutingName},#{defaultRoutingVersionId},#{sourceSystem},#{sourceId},#{checkBy},#{checkTime},#{closeBy},#{closeTime},#{remark},#{createBy},sysdate())
    </insert>
    <update id="updateBomVersion" parameterType="BomVersion">
        update bom_version
        <set>
            <if test="versionCode != null and versionCode != ''">version_code=#{versionCode},</if><if test="versionName != null">version_name=#{versionName},</if><if test="versionDesc != null">version_desc=#{versionDesc},</if>
            <if test="baseQty != null">base_qty=#{baseQty},</if><if test="usageType != null and usageType != ''">usage_type=#{usageType},</if><if test="effectiveDate != null">effective_date=#{effectiveDate},</if><if test="expireDate != null">expire_date=#{expireDate},</if>
            <if test="status != null and status != ''">status=#{status},</if><if test="approveStatus != null and approveStatus != ''">approve_status=#{approveStatus},</if><if test="defaultFlag != null">default_flag=#{defaultFlag},</if>
            <if test="defaultRoutingCode != null">default_routing_code=#{defaultRoutingCode},</if><if test="defaultRoutingName != null">default_routing_name=#{defaultRoutingName},</if><if test="defaultRoutingVersionId != null">default_routing_version_id=#{defaultRoutingVersionId},</if>
            <if test="sourceSystem != null">source_system=#{sourceSystem},</if><if test="sourceId != null">source_id=#{sourceId},</if><if test="checkBy != null">check_by=#{checkBy},</if><if test="checkTime != null">check_time=#{checkTime},</if><if test="closeBy != null">close_by=#{closeBy},</if><if test="closeTime != null">close_time=#{closeTime},</if><if test="remark != null">remark=#{remark},</if>
            <if test="updateBy != null and updateBy != ''">update_by=#{updateBy},</if>update_time=sysdate()
        </set>
        where id=#{id}
    </update>
    <delete id="deleteBomVersionByIds" parameterType="String">delete from bom_version where id in <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
    <delete id="deleteBomVersionByMasterIds" parameterType="String">delete from bom_version where bom_master_id in <foreach collection="array" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
