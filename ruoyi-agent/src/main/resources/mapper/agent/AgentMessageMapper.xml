<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.agent.mapper.AgentMessageMapper">
    <resultMap id="MessageResult" type="com.ruoyi.agent.domain.AgentMessage">
        <id property="id" column="id"/><result property="conversationId" column="conversation_id"/>
        <result property="difyMessageId" column="dify_message_id"/><result property="taskId" column="task_id"/>
        <result property="workflowRunId" column="workflow_run_id"/><result property="role" column="role"/>
        <result property="content" column="content"/><result property="eventLog" column="event_log"/>
        <result property="metadata" column="metadata"/><result property="tokenCount" column="token_count"/>
        <result property="status" column="status"/><result property="errorMessage" column="error_message"/>
        <result property="createBy" column="create_by"/><result property="createTime" column="create_time"/>
    </resultMap>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">insert into agent_message(conversation_id,dify_message_id,task_id,workflow_run_id,role,content,event_log,metadata,token_count,status,error_message,create_by,create_time) values(#{conversationId},#{difyMessageId},#{taskId},#{workflowRunId},#{role},#{content},#{eventLog},#{metadata},#{tokenCount},#{status},#{errorMessage},#{createBy},sysdate())</insert>
    <update id="update">update agent_message set dify_message_id=#{difyMessageId},task_id=#{taskId},workflow_run_id=#{workflowRunId},content=#{content},event_log=#{eventLog},metadata=#{metadata},token_count=#{tokenCount},status=#{status},error_message=#{errorMessage} where id=#{id}</update>
    <select id="selectByConversationId" resultMap="MessageResult">select * from agent_message where conversation_id=#{conversationId} order by id</select>
    <delete id="deleteByConversationId">delete from agent_message where conversation_id=#{conversationId}</delete>
</mapper>
