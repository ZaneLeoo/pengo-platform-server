<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.agent.mapper.runtime.AgentRunEventMapper">
    <resultMap id="EventResult" type="com.ruoyi.agent.domain.runtime.AgentRunEvent">
        <id property="id" column="id"/>
        <result property="runId" column="run_id"/>
        <result property="sequenceNo" column="sequence_no"/>
        <result property="eventType" column="event_type"/>
        <result property="dataJson" column="data_json"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into agent_run_event(run_id, sequence_no, event_type, data_json, create_time)
        values(#{runId}, #{sequenceNo}, #{eventType}, #{dataJson}, sysdate())
    </insert>
    <select id="selectAfter" resultMap="EventResult">
        select * from agent_run_event where run_id=#{runId} and sequence_no &gt; #{sequenceNo}
        order by sequence_no limit 1000
    </select>
</mapper>
