<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.agent.mapper.AgentConversationMapper">

    <resultMap type="com.ruoyi.agent.domain.AgentConversation" id="AgentConversationResult">
        <result property="id"                   column="id"                     />
        <result property="userId"               column="user_id"               />
        <result property="difyConversationId"   column="dify_conversation_id"  />
        <result property="title"                column="title"                 />
        <result property="status"               column="status"                />
        <result property="messageCount"         column="message_count"         />
        <result property="createBy"             column="create_by"             />
        <result property="createTime"           column="create_time"           />
        <result property="updateBy"             column="update_by"             />
        <result property="updateTime"           column="update_time"           />
        <result property="remark"               column="remark"                />
    </resultMap>

    <sql id="selectAgentConversationVo">
        select id, user_id, dify_conversation_id, title, status, message_count,
               create_by, create_time, update_by, update_time, remark
        from agent_conversation
    </sql>

    <select id="selectConversationList" parameterType="Long" resultMap="AgentConversationResult">
        <include refid="selectAgentConversationVo"/>
        where user_id = #{userId}
        order by update_time desc
    </select>

    <select id="selectConversationById" parameterType="Long" resultMap="AgentConversationResult">
        <include refid="selectAgentConversationVo"/>
        where id = #{id}
    </select>

    <insert id="insertConversation" parameterType="com.ruoyi.agent.domain.AgentConversation" useGeneratedKeys="true" keyProperty="id">
        insert into agent_conversation
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="difyConversationId != null">dify_conversation_id,</if>
            <if test="title != null">title,</if>
            <if test="status != null">status,</if>
            <if test="messageCount != null">message_count,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="difyConversationId != null">#{difyConversationId},</if>
            <if test="title != null">#{title},</if>
            <if test="status != null">#{status},</if>
            <if test="messageCount != null">#{messageCount},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateConversation" parameterType="com.ruoyi.agent.domain.AgentConversation">
        update agent_conversation
        <set>
            <if test="difyConversationId != null">dify_conversation_id = #{difyConversationId},</if>
            <if test="title != null">title = #{title},</if>
            <if test="status != null">status = #{status},</if>
            <if test="messageCount != null">message_count = #{messageCount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <delete id="deleteConversationById" parameterType="Long">
        delete from agent_conversation where id = #{id}
    </delete>

</mapper>
