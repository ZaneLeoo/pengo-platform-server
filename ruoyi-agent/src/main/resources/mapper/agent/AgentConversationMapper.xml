<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.agent.mapper.AgentConversationMapper">
    <resultMap id="ConversationResult" type="com.ruoyi.agent.domain.AgentConversation">
        <id property="id" column="id"/><result property="userId" column="user_id"/>
        <result property="difyConversationId" column="dify_conversation_id"/><result property="title" column="title"/>
        <result property="status" column="status"/><result property="lastTaskId" column="last_task_id"/>
        <result property="lastWorkflowRunId" column="last_workflow_run_id"/><result property="messageCount" column="message_count"/>
        <result property="createBy" column="create_by"/><result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/><result property="updateTime" column="update_time"/>
    </resultMap>
    <sql id="columns">select id,user_id,dify_conversation_id,title,status,last_task_id,last_workflow_run_id,message_count,create_by,create_time,update_by,update_time from agent_conversation</sql>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into agent_conversation(user_id,title,status,message_count,create_by,create_time)
        values(#{userId},#{title},#{status},#{messageCount},#{createBy},sysdate())
    </insert>
    <select id="selectByUserId" resultMap="ConversationResult"><include refid="columns"/> where user_id=#{userId} and status!='deleted' order by update_time desc, id desc</select>
    <select id="selectOwned" resultMap="ConversationResult"><include refid="columns"/> where id=#{id} and user_id=#{userId} and status!='deleted'</select>
    <update id="update">update agent_conversation set title=#{title},dify_conversation_id=#{difyConversationId},status=#{status},last_task_id=#{lastTaskId},last_workflow_run_id=#{lastWorkflowRunId},message_count=#{messageCount},update_by=#{updateBy},update_time=sysdate() where id=#{id}</update>
    <update id="deleteOwned">update agent_conversation set status='deleted',update_time=sysdate() where id=#{id} and user_id=#{userId}</update>
</mapper>
